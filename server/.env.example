PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/realtime-chat
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_IDS=replace-with-google-client-id,replace-with-mobile-google-client-id
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
CLOUDINARY_FOLDER=canvas-chat
MESSAGE_RETENTION_DAYS=90
CHAT_RETENTION_DAYS=120
RETENTION_CLEANUP_INTERVAL_HOURS=6
